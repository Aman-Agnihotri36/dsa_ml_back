2025-09-29 22:24:08 | app_logger | INFO | C:\Users\agnih\OneDrive\Documents\Desktop\back\mocktest_backend\my_project\src\modules\tests\testGenAI.py: sol:#include <iostream>
#include <vector>
using namespace std;

int maxSubarraySumOf3(vector<int>& prices) {
    int n = prices.size();
    if (n < 3) return -1; // not enough elements

    // First window sum
    int windowSum = prices[0] + prices[1] + prices[2];
    int maxSum = windowSum;

    // Slide the window
    for (int i = 3; i < n; i++) {
        windowSum = windowSum - prices[i - 3] + prices[i];
        maxSum = max(maxSum, windowSum);
    }

    return maxSum;
}

int main() {
    vector<int> prices = {1, 2, 3, 4, 5};
    cout << "Maximum subarray sum of size 3: " << maxSubarraySumOf3(prices) << endl;
    return 0;
}

