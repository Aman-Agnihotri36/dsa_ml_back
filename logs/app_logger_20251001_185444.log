2025-10-01 18:59:05 | app_logger | INFO | C:\Users\agnih\OneDrive\Documents\Desktop\back\mocktest_backend\my_project\src\modules\tests\testGenAI.py: sol:#include <iostream>
#include <vector>
#include <numeric> // for accumulate
using namespace std;

int countAboveAverage(vector<int>& scores) {
    int n = scores.size();
    
    // Step 1: Calculate average
    double avg = (double)accumulate(scores.begin(), scores.end(), 0) / n;
    
    // Step 2: Binary search to find first element > avg
    int low = 0, high = n - 1, ans = n;
    while (low <= high) {
        int mid = low + (high - low) / 2;
        if (scores[mid] > avg) {
            ans = mid;  // potential answer
            high = mid - 1;
        } else {
            low = mid + 1;
        }
    }
    
    // Step 3: Count of students above average
    return n - ans;
}

int main() {
    vector<int> scores = {1, 2, 3, 4, 5};
    cout << countAboveAverage(scores) << endl; // Output: 2
    return 0;
}

